# Public Mapbox token (same restrictions as Mapbox docs — use URL restrictions in production)
VITE_MAPBOX_ACCESS_TOKEN=pk.your_token_here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Optional: monument API origin when the UI is not served by Vite (e.g. Live Server on a static build).
# Leave unset for `npm run dev` — Vite proxies /api to the backend.
# VITE_API_BASE_URL=http://127.0.0.1:5001
