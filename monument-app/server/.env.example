# Default 5001: macOS AirPlay Receiver often uses 5000 (EADDRINUSE)
# From repo root, `npm run combined` serves API + static site on this port (open http://localhost:5001/)
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/monument_app
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Google Sign-In (GIS) — verify ID tokens; must match the client’s VITE_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Standalone admin dashboard: POST /api/admin/auth/login — required in production (dev defaults admin / admin).
# ADMIN_ID=admin
# ADMIN_PASSWORD=use-a-strong-secret
# ADMIN_JWT_EXPIRES_IN=8h
